# Copy to .env and adjust. Keep caches on data disk (see SETUP.md).

# --- Disk / Hugging Face (avoid filling system drive) ---
HF_HOME=/DATA/disk4/workspace/zhongjian/memory/.cache/huggingface
TRANSFORMERS_CACHE=${HF_HOME}/transformers

# --- vLLM OpenAI-compatible API (Qwen3-8B) ---
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL_NAME=Qwen3-8B

# --- Embedding backend ---
# openai: use deployed embedding service (recommended for 32B main model);
# local: load local HF embedding model in Python process.
EMBEDDING_BACKEND=openai
EMBEDDING_BASE_URL=http://127.0.0.1:8001/v1
EMBEDDING_API_KEY=EMPTY
EMBEDDING_MODEL_NAME=Qwen3-Embedding-0.6B

# --- Local embedding model directory (used when EMBEDDING_BACKEND=local) ---
EMBEDDING_MODEL_PATH=/DATA/disk4/workspace/zhongjian/memory/cache/models/Qwen/Qwen3-Embedding-0___6B

# Embedding vector size for Qwen3-Embedding-0.6B default full dim
EMBEDDING_DIM=1024
# cuda | cpu | cuda:0 （仅在 EMBEDDING_BACKEND=local 时生效）
EMBEDDING_DEVICE=cuda

# --- Qdrant ---
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=agentic_rag_docs
# 检索条数（长篇小说可适当增大，如 12～20）
RETRIEVE_K=8

# retrieve：先向量检索再回答（默认，不依赖 vLLM 工具解析）；react：LangGraph ReAct 工具调用
RAG_MODE=retrieve
