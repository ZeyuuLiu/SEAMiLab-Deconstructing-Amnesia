# TiMem Cloud Service Configuration
# ========================================
# TiMem Cloud API Credentials
TIMEM_USERNAME=your_username
TIMEM_PASSWORD=your_password

# TiMem Cloud API URL
TIMEM_BASE_URL=https://api.timem.cloud

# Optional: LLM API Key (for AI assistant examples)
# ZHIPUAI_API_KEY=your_zhipuai_api_key



# TiMem Self-Host Configuration
# ========================================
# Quick start: Only variables marked [REQUIRED] are needed
# Documentation: See docs/configuration.md
#
# Setup instructions:
# 1. Copy this file to .env: cp env.example .env
# 2. Fill in your API keys below
# 3. Run: source .venv/bin/activate (or .venv\Scripts\activate on Windows)

# ----------------------------------------
# Core Configuration [REQUIRED]
# ----------------------------------------

# Dataset profile: 'default' for LoCoMo, 'longmemeval_s' for LongMemEval-S
# For more options, see config/dataset_profiles.yaml
TIMEM_DATASET_PROFILE=default

# LLM Provider API Key [REQUIRED]
# Choose one: OpenAI, Anthropic, ZhipuAI, or Qwen
# Only one needs to be set for basic operation
OPENAI_API_KEY=your_openai_key_here
# CLAUDE_API_KEY=your_claude_key_here
# ZHIPUAI_API_KEY=your_zhipuai_key_here
# QWEN_API_KEY=your_qwen_key_here

# ----------------------------------------
# Database Configuration [IMPORTANT]
# ----------------------------------------
# There are TWO environments with different settings:

# === LOCAL DEVELOPMENT (default) ===
# Use these settings when running databases via Docker Compose
# from your local machine for development/testing:
POSTGRES_HOST=localhost
POSTGRES_PORT=15432
POSTGRES_USER=timem_user
POSTGRES_PASSWORD=timem_password
POSTGRES_DATABASE=timem_db

QDRANT_URL=http://localhost:16333
QDRANT_API_KEY=

NEO4J_URI=bolt://localhost:17687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_PASSWORD=

# === DOCKER CONTAINER ENVIRONMENT ===
# When running INSIDE Docker containers (e.g., TiMem API container),
# use container names instead of localhost:
# POSTGRES_HOST=postgres
# QDRANT_URL=http://qdrant:6333
# NEO4J_URI=bolt://neo4j:7687
# REDIS_HOST=redis

# === PRODUCTION ENVIRONMENT ===
# For production deployment, use external database services:
# POSTGRES_HOST=your-production-db.example.com
# POSTGRES_PORT=5432
# (Update other services accordingly)

# ----------------------------------------
# Advanced Configuration [OPTIONAL]
# ----------------------------------------
# See docs/configuration.md for details

# LLM Provider (default: auto-detect based on API key)
# Options: openai, anthropic, zhipuai, qwen
# TIMEM_LLM_DEFAULT_PROVIDER=openai

# Model selection (optional, uses provider default if not set)
# OPENAI_MODEL=gpt-4o-mini
# CLAUDE_MODEL=claude-3-5-sonnet-20241022
# ZHIPUAI_MODEL=glm-4-flash
# QWEN_MODEL=qwen-turbo

# Local Model Configuration (for using local LLM models)
# QWEN_MODEL_PATH=./models/Qwen3-8B
# QWEN_EMBEDDING_PATH=./models/Qwen3-Embedding-0.6B

# ----------------------------------------
# Application Configuration [OPTIONAL]
# ----------------------------------------
# APP_SECRET_KEY=your_secure_app_secret_key_here
# APP_DEBUG=false
# LOG_LEVEL=INFO
# ENVIRONMENT=development

# ----------------------------------------
# Monitoring Configuration [OPTIONAL]
# ----------------------------------------
# PROMETHEUS_ENABLED=true
# GRAFANA_ENABLED=true
